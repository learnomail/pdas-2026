<form action="/backend/process-visitor.php" method="POST" class="max-w-3xl mx-auto p-8 bg-white shadow-lg rounded-xl">
  
  <!-- 01 Personal Information -->
  <h3 class="text-xl font-bold text-blue-900 mb-4">01 Personal Information</h3>
  <p class="text-sm text-gray-500 mb-4">Details for your secure entry badge</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <input type="text" name="full_name" placeholder="Full Name" required class="border p-3 rounded w-full">
    <input type="text" name="designation" placeholder="Designation" required class="border p-3 rounded w-full">
    <input type="text" name="organization" placeholder="Organization Name" required class="border p-3 rounded w-full md:col-span-2">
    <input type="email" name="email" placeholder="Official Email" required class="border p-3 rounded w-full">
    <input type="tel" name="contact_number" placeholder="Contact Number" required class="border p-3 rounded w-full">
  </div>

  <!-- 02 Professional Category -->
  <h3 class="text-xl font-bold text-blue-900 mb-4">02 Professional Category</h3>
  <p class="text-sm text-gray-500 mb-4">Select your primary affiliation</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <label><input type="radio" name="category" value="Trade / Industry" required> Trade / Industry</label>
    <label><input type="radio" name="category" value="Defence / Military"> Defence / Military</label>
    <label><input type="radio" name="category" value="Govt / PSU"> Govt / PSU</label>
    <label><input type="radio" name="category" value="R&D / Academic"> R&D / Academic</label>
    <label><input type="radio" name="category" value="Student"> Student</label>
    <label><input type="radio" name="category" value="Press / Media"> Press / Media</label>
  </div>

  <!-- 03 Areas of Interest -->
  <h3 class="text-xl font-bold text-blue-900 mb-4">03 Areas of Interest</h3>
  <p class="text-sm text-gray-500 mb-4">Choose segments that align with your mission</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <label><input type="checkbox" name="interests[]" value="Drones & UAV Systems"> Drones & UAV Systems</label>
    <label><input type="checkbox" name="interests[]" value="AI & Cyber Warfare"> AI & Cyber Warfare</label>
    <label><input type="checkbox" name="interests[]" value="Maritime Security"> Maritime Security</label>
    <label><input type="checkbox" name="interests[]" value="Domestic Manufacturing"> Domestic Manufacturing</label>
  </div>

  <!-- Confirmation -->
  <div class="bg-gray-50 p-4 rounded-lg mb-8 border">
    <label class="flex items-start text-sm text-gray-700">
      <input type="checkbox" name="confirm" required class="mt-1 mr-3">
      I confirm that the information provided is accurate. I understand that I must carry a valid government issued photo ID to the Chennai Trade Centre for security verification.
    </label>
  </div>

  <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded">
    Complete Registration
  </button>
</form>