---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Why To Participate | PDAS 2026">
  <section class="bg-[#070d1e] pt-12 pb-24 px-4 md:px-8 border-b border-slate-800 relative overflow-hidden">
    <!-- Grid Background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 48px 48px;"></div>
    
    <div class="max-w-screen-xl mx-auto relative z-10">
      
      <!-- DATA HEADER -->
      <div class="border-b border-slate-800 pb-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <span class="relative w-2.5 h-2.5 flex items-center justify-center">
            <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
            <span class="relative w-2.5 h-2.5 bg-sky-400 rounded-full block"></span>
          </span>
          <p class="text-[11px] uppercase font-mono tracking-[0.2em] text-slate-400">
            SYS.DIR // ABOUT // WHY TO PARTICIPATE
          </p>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter">
          Why To Participate
        </h1>
      </div>

      <!-- GRID -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- CARD 1 -->
        <div class="border border-slate-800 bg-slate-900/50 p-8 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-3xl mb-6 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">📢</div>
          <h3 class="text-xl font-bold text-white uppercase tracking-tight mb-3">Brand Visibility</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Showcase your capabilities and innovations to global buyers and officials.
          </p>
        </div>

        <!-- CARD 2 -->
        <div class="border border-slate-800 bg-slate-900/50 p-8 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-3xl mb-6 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🤝</div>
          <h3 class="text-xl font-bold text-white uppercase tracking-tight mb-3">Business Development</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Build partnerships and expand networks through B2B meetings.
          </p>
        </div>

        <!-- CARD 3 -->
        <div class="border border-slate-800 bg-slate-900/50 p-8 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-3xl mb-6 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">⚙️</div>
          <h3 class="text-xl font-bold text-white uppercase tracking-tight mb-3">Technology Exposure</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Present latest technologies to decision-makers and investors.
          </p>
        </div>

        <!-- CARD 4 -->
        <div class="border border-slate-800 bg-slate-900/50 p-8 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-3xl mb-6 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">💡</div>
          <h3 class="text-xl font-bold text-white uppercase tracking-tight mb-3">Knowledge Sharing</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Participate in discussions, workshops, and expert sessions.
          </p>
        </div>

        <!-- CARD 5 -->
        <div class="border border-slate-800 bg-slate-900/50 p-8 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group md:col-span-2 lg:col-span-1">
          <div class="text-3xl mb-6 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🏛️</div>
          <h3 class="text-xl font-bold text-white uppercase tracking-tight mb-3">Government Engagement</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Connect with officials and stay updated with policies.
          </p>
        </div>

      </div>

    </div>
  </section>
</Layout>