---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro'; // Assuming it sits here
---

<Layout title="Register to Exhibit | PDAS 2026">
  <Header />

  <!-- HERO HEADER TERMINAL -->
  <section class="relative min-h-[40vh] flex flex-col justify-center border-b border-slate-800 overflow-hidden pt-20">
    <div class="absolute inset-0 z-0">
      <img src="/images/home/pdas-aerospace.png" alt="Aerospace Terminal" class="w-full h-full object-cover opacity-20 grayscale mix-blend-luminosity" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#020617] via-[#020617]/60 to-[#020617]/40"></div>
    </div>

    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <div class="flex items-center gap-4 mb-4">
        <span class="relative w-2.5 h-2.5 flex items-center justify-center">
          <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
          <span class="relative w-2.5 h-2.5 bg-sky-400 rounded-full block"></span>
        </span>
        <p class="text-[11px] uppercase font-mono tracking-[0.2em] text-slate-400">
          SECURE SEC. // SYS.ENTRY // PORTAL-01
        </p>
      </div>

      <h1 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter leading-none mb-4">
        Register to<br />
        <span class="text-transparent" style="-webkit-text-stroke: 1px white;">Exhibit</span>
      </h1>
      <p class="text-slate-400 text-sm font-mono max-w-xl leading-relaxed border-l-2 border-sky-400 pl-4">
        Exhibitor Space Application for PDAS 2026. Complete all industrial metric specifications and key representative classifications below.
      </p>
    </div>
  </section>

  <!-- FORM BASE -->
  <section class="py-24 bg-[#020617] relative">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      
      <!-- Connects directly to your backend processor -->
      <form action="https://your-live-domain.com/process_exhibitor.php" method="POST" class="space-y-12">
        
        <!-- SECTION 01: CORPORATE ENTITY IDENTIFICATION -->
        <div class="border border-slate-800 bg-slate-900/40 rounded-xl p-6 sm:p-10 relative overflow-hidden group hover:border-slate-700 transition-colors">
          <div class="flex items-center gap-3 mb-8">
            <p class="text-sky-400 font-mono text-[11px] uppercase tracking-widest">01 // Corporate Entity Identification</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <label class="block text-[10px] font-mono text-slate-400 uppercase tracking-wider mb-2">Full Exhibitor / Company Name *</label>
              <input type="text" name="exhibitor_name" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-sm px-4 py-3.5 focus:border-sky-400 focus:outline-none transition-colors" placeholder="ENTER LEGAL RECORD" />
            </div>
            <div>
              <label class="block text-[10px] font-mono text-slate-400 uppercase tracking-wider mb-2">Invoicing Company Name *</label>
              <input type="text" name="invoice_name" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-sm px-4 py-3.5 focus:border-sky-400 focus:outline-none transition-colors" placeholder="BILLING DESIGNATION" />
            </div>
            <div>
              <label class="block text-[10px] font-mono text-slate-400 uppercase tracking-wider mb-2">GST Registration Number *</label>
              <input type="text" name="gst_number" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-sm px-4 py-3.5 focus:border-sky-400 focus:outline-none transition-colors" placeholder="22AAAAA0000A1Z5" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-[10px] font-mono text-slate-400 uppercase tracking-wider mb-2">Registered Office Address *</label>
              <input type="text" name="office_address" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-sm px-4 py-3.5 focus:border-sky-400 focus:outline-none transition-colors" placeholder="HQ ARCHIVE DATA LOCATION" />
            </div>
          </div>
        </div>

        <!-- SECTION 02: RELEVANT SECTOR ALIGNMENT -->
        <div class="border border-slate-800 bg-slate-900/40 rounded-xl p-6 sm:p-10 relative overflow-hidden group hover:border-slate-700 transition-colors">
          <div class="flex items-center gap-3 mb-8">
            <p class="text-sky-400 font-mono text-[11px] uppercase tracking-widest">02 // Relevant Sector Alignment</p>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {['sector_defence', 'sector_aero', 'sector_naval', 'sector_space', 'sector_electronics', 'sector_cyber'].map((sector) => {
              const titles = {
                sector_defence: 'Defence Manufacturing',
                sector_aero: 'Aerospace Systems',
                sector_naval: 'Naval / Maritime Systems',
                sector_space: 'Space Technologies',
                sector_electronics: 'Electronics & Avionics',
                sector_cyber: 'AI / Cyber Defence'
              };
              return (
                <label class="flex items-center gap-3 border border-slate-800/80 bg-[#020617]/60 rounded-lg p-4 cursor-pointer hover:border-sky-400/50 hover:bg-slate-900/40 group/label transition-all">
                  <input type="checkbox" name={sector} class="w-4 h-4 bg-[#020617] border-slate-800 text-blue-600 focus:ring-0 focus:ring-offset-0 rounded" />
                  <span class="text-sm font-mono text-slate-400 group-hover/label:text-white transition-colors">{titles[sector]}</span>
                </label>
              )
            })}
          </div>
        </div>

        <!-- SECTION 03: KEY REPRESENTATIVES RECORD -->
        <div class="border border-slate-800 bg-slate-900/40 rounded-xl p-6 sm:p-10 relative overflow-hidden group hover:border-slate-700 transition-colors">
          <div class="flex items-center gap-3 mb-8">
            <p class="text-sky-400 font-mono text-[11px] uppercase tracking-widest">03 // Key Representatives Record</p>
          </div>
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- CEO Block -->
            <div class="border border-slate-800 bg-[#020617]/50 rounded-xl p-6 space-y-4">
              <h4 class="text-white text-xs font-mono uppercase tracking-widest border-b border-slate-800 pb-3 text-slate-300 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span> CEO / Managing Director
              </h4>
              <input type="text" name="owner_name" placeholder="Full Name *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
              <input type="text" name="owner_mobile" placeholder="Mobile Security Link *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
              <input type="email" name="owner_email" placeholder="Official Network Email ID *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
            </div>

            <!-- Primary Contact Block -->
            <div class="border border-slate-800 bg-[#020617]/50 rounded-xl p-6 space-y-4">
              <h4 class="text-white text-xs font-mono uppercase tracking-widest border-b border-slate-800 pb-3 text-slate-300 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Primary Command Contact
              </h4>
              <input type="text" name="contact_name" placeholder="Full Name *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
              <input type="text" name="contact_mobile" placeholder="Mobile Security Link *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
              <input type="email" name="contact_email" placeholder="Official Network Email ID *" required class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-xs px-4 py-3 focus:border-sky-400 focus:outline-none" />
            </div>
          </div>
        </div>

        <!-- SECTION 04: INFRASTRUCTURE & INVESTMENT ALLOCATION -->
        <div class="border border-slate-800 bg-slate-900/40 rounded-xl p-6 sm:p-10 relative overflow-hidden group hover:border-slate-700 transition-colors">
          <div class="flex items-center gap-3 mb-8">
            <p class="text-sky-400 font-mono text-[11px] uppercase tracking-widest">04 // Infrastructure Space Selection</p>
          </div>
          
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Options Controls -->
            <div class="lg:col-span-7 space-y-4">
              <label class="block border border-slate-800 bg-[#020617] p-5 rounded-lg cursor-pointer hover:border-sky-400/60 transition-colors relative">
                <div class="flex items-start gap-4">
                  <input type="radio" name="space_option" id="option1" value="Bare Space" checked class="mt-1 text-blue-600 focus:ring-0" />
                  <div>
                    <h5 class="text-white font-mono text-sm font-bold uppercase">Option 1: Bare Space</h5>
                    <p class="text-slate-500 font-mono text-[11px] mt-1">₹10,000 / SQM | MIN 24 SQM inside AC Hall. No panels/lights.</p>
                  </div>
                </div>
              </label>

              <label class="block border border-slate-800 bg-[#020617] p-5 rounded-lg cursor-pointer hover:border-sky-400/60 transition-colors relative">
                <div class="flex items-start gap-4">
                  <input type="radio" name="space_option" id="option2" value="Built-Up Stall" class="mt-1 text-blue-600 focus:ring-0" />
                  <div>
                    <h5 class="text-white font-mono text-sm font-bold uppercase">Option 2: Built-Up Stall</h5>
                    <p class="text-slate-500 font-mono text-[11px] mt-1">₹12,000 / SQM | MIN 9 SQM. Includes structural walls, carpet, fascia, electrical hooks.</p>
                  </div>
                </div>
              </label>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
                <div>
                  <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">Metrics Required (SQM) *</label>
                  <input type="number" min="9" max="40" name="space_required" id="sqmValue" required placeholder="e.g., 24" class="w-full bg-[#020617] border border-slate-800 rounded-lg text-white font-mono text-sm px-4 py-3 focus:border-sky-400 focus:outline-none" />
                </div>
                <div class="flex items-end pb-3.5">
                  <label class="flex items-center gap-3 text-slate-400 font-mono text-xs cursor-pointer hover:text-white transition-colors">
                    <input type="checkbox" name="space_location" id="primeLocation" class="w-4 h-4 rounded text-blue-600 focus:ring-0 bg-[#020617] border-slate-800" />
                    Prime Tactical Location (+10%)
                  </label>
                </div>
              </div>
            </div>

            <!-- Calculated Live Terminal Summary -->
            <div class="lg:col-span-5 border border-slate-800 rounded-lg bg-[#020617] p-6 relative flex flex-col justify-between">
              <div class="absolute top-0 left-0 w-full h-0.5 bg-slate-900"><div class="w-1/2 h-full bg-gradient-to-r from-blue-700 to-[#008718]"></div></div>
              <div>
                <h4 class="text-xs font-mono text-sky-400 uppercase tracking-widest border-b border-slate-800 pb-3 mb-4">Investment Balance Output</h4>
                <div class="space-y-2 font-mono text-xs">
                  <div class="flex justify-between"><span class="text-slate-500">Allocation:</span> <span id="summary_option" class="text-white">Option 1</span></div>
                  <div class="flex justify-between"><span class="text-slate-500">Space Cost:</span> <span id="summary_spaceCost" class="text-white">₹0</span></div>
                  <div class="flex justify-between"><span class="text-slate-500">Premium Mod:</span> <span id="summary_primeCharges" class="text-white">₹0</span></div>
                  <div class="flex justify-between"><span class="text-slate-500">Sovereign GST (18%):</span> <span id="summary_gstValue" class="text-white">₹0</span></div>
                </div>
              </div>
              <div class="border-t border-slate-800 pt-4 mt-6 flex justify-between items-baseline font-mono">
                <span class="text-slate-400 text-xs uppercase tracking-wider">Gross Total:</span>
                <span id="summary_totalAmount" class="text-sky-400 font-black text-xl tabular-nums">₹0</span>
              </div>
            </div>
          </div>
        </div>

        <!-- SECTION 05: SECURE REMITTANCE DETAILS -->
        <div class="border border-slate-800 bg-slate-900/40 rounded-xl p-6 sm:p-10 relative overflow-hidden group hover:border-slate-700 transition-colors">
          <div class="flex items-center gap-3 mb-8">
            <p class="text-sky-400 font-mono text-[11px] uppercase tracking-widest">05 // Secure Remittance Details</p>
          </div>
          
          <div class="bg-[#020617] border border-slate-800 rounded-lg p-6 relative">
            <!-- Tactical accent line -->
            <div class="absolute top-0 left-0 w-1 h-full bg-emerald-500 rounded-l-lg"></div>
            
            <div class="w-full font-mono">
              <p class="text-slate-400 text-xs leading-relaxed border-b border-slate-800 pb-4 mb-5">
                <span class="text-emerald-500">SYSTEM NOTE:</span> Please remit the required 50% advance payment to the following operational account to confirm your infrastructure booking.
              </p>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="bg-slate-900/50 p-4 border border-slate-800/80 rounded">
                  <span class="block text-[10px] text-slate-500 uppercase tracking-widest mb-1">Beneficiary Name</span>
                  <span class="text-white font-bold tracking-wide text-sm">THE PENINSULA FOUNDATION</span>
                </div>
                
                <!-- Bank -->
                <div class="bg-slate-900/50 p-4 border border-slate-800/80 rounded">
                  <span class="block text-[10px] text-slate-500 uppercase tracking-widest mb-1">Bank Institution</span>
                  <span class="text-white font-bold tracking-wide text-sm">HDFC BANK</span>
                </div>
                
                <!-- Account -->
                <div class="bg-slate-900/50 p-4 border border-sky-900/30 rounded shadow-[0_0_15px_-3px_rgba(56,189,248,0.1)]">
                  <span class="block text-[10px] text-sky-400/70 uppercase tracking-widest mb-1">Account Number</span>
                  <span class="text-sky-400 font-black tracking-wider text-lg tabular-nums">50200028083960</span>
                </div>
                
                <!-- IFSC -->
                <div class="bg-slate-900/50 p-4 border border-slate-800/80 rounded">
                  <span class="block text-[10px] text-slate-500 uppercase tracking-widest mb-1">IFSC Code</span>
                  <span class="text-white font-bold tracking-wider text-sm">HDFC0000017</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- CONTROL DISPATCH BUTTON -->
        <button type="submit" name="submit" class="w-full bg-gradient-to-r from-blue-700 to-[#008718] text-white font-mono text-sm uppercase tracking-[0.2em] py-5 font-bold rounded-xl shadow-lg shadow-blue-900/20 hover:scale-[1.01] transition-all flex items-center justify-center gap-3">
          Dispatch System Registration Request
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>

      </form>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const sqmInput = document.getElementById('sqmValue');
    const opt1 = document.getElementById('option1');
    const opt2 = document.getElementById('option2');
    const primeCheck = document.getElementById('primeLocation');

    const sOpt = document.getElementById('summary_option');
    const sCost = document.getElementById('summary_spaceCost');
    const sPrime = document.getElementById('summary_primeCharges');
    const sGst = document.getElementById('summary_gstValue');
    const sTotal = document.getElementById('summary_totalAmount');

    function calculateValues() {
      let sqm = parseInt(sqmInput.value) || 0;
      let perSqm = opt1.checked ? 10000 : 12000;
      
      sOpt.textContent = opt1.checked ? "Option 1: Bare Space" : "Option 2: Built-Up Stall";
      
      let spaceCost = sqm * perSqm;
      let primeCharges = primeCheck.checked ? (spaceCost * 0.1) : 0;
      let calculatedBase = spaceCost + primeCharges;
      let gst = calculatedBase * 0.18;
      let grossTotal = calculatedBase + gst;

      sCost.textContent = "₹" + spaceCost.toLocaleString('en-IN');
      sPrime.textContent = "₹" + primeCharges.toLocaleString('en-IN');
      sGst.textContent = "₹" + gst.toLocaleString('en-IN');
      sTotal.textContent = "₹" + grossTotal.toLocaleString('en-IN');
    }

    sqmInput.addEventListener('input', calculateValues);
    opt1.addEventListener('change', calculateValues);
    opt2.addEventListener('change', calculateValues);
    primeCheck.addEventListener('change', calculateValues);
  });
</script>