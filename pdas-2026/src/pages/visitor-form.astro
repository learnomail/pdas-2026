---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Register to Visit - PDAS 2026">
  <main class="pt-40 pb-20 max-w-3xl mx-auto px-4">
    <div class="bg-[#0b1329] border border-slate-800 p-8 rounded-xl shadow-2xl">
      <h1 class="text-3xl font-bold text-white mb-2">Visitor Registration</h1>
      <p class="text-slate-400 mb-8 text-sm">Please provide your details to generate your secure entry badge.</p>
      
      <form id="registrationForm" class="space-y-6">
        <!-- Personal Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" name="name" placeholder="Full Name" required class="w-full p-3 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 focus:border-sky-500 focus:outline-none" />
          <input type="text" name="designation" placeholder="Designation" required class="w-full p-3 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 focus:border-sky-500 focus:outline-none" />
          <input type="text" name="org" placeholder="Organization Name" class="col-span-full p-3 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 focus:border-sky-500 focus:outline-none" />
          <input type="email" name="email" placeholder="Official Email" required class="p-3 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 focus:border-sky-500 focus:outline-none" />
          <input type="tel" name="phone" placeholder="Contact Number" class="p-3 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 focus:border-sky-500 focus:outline-none" />
        </div>

        <!-- Professional Category -->
        <div>
          <label class="block text-slate-400 mb-3 text-sm font-semibold uppercase tracking-wider">Professional Category</label>
          <div class="grid grid-cols-2 gap-3">
            {['Trade / Industry', 'Defence / Military', 'Govt / PSU', 'R&D / Academic', 'Student', 'Press / Media'].map((cat) => (
              <label class="flex items-center text-slate-300 text-sm cursor-pointer hover:text-white">
                <input type="radio" name="category" value={cat} required class="mr-2 accent-sky-500" /> {cat}
              </label>
            ))}
          </div>
        </div>

        <!-- Areas of Interest -->
        <div>
          <label class="block text-slate-400 mb-3 text-sm font-semibold uppercase tracking-wider">Areas of Interest</label>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {['Drones & UAV Systems', 'AI & Cyber Warfare', 'Maritime Security', 'Domestic Manufacturing'].map((area) => (
              <label class="flex items-center text-slate-300 text-sm cursor-pointer hover:text-white">
                <input type="checkbox" name="interest" value={area} class="mr-2 accent-sky-500" /> {area}
              </label>
            ))}
          </div>
        </div>

        <button type="submit" id="submitBtn" class="w-full py-4 bg-[#008718] text-white font-bold rounded-lg hover:bg-[#006e14] transition-all">
          Submit Registration
        </button>
      </form>

      <div id="successMessage" class="hidden mt-6 p-6 bg-green-900/20 border border-green-700 text-green-400 rounded-lg text-center">
        <h3 class="text-xl font-bold mb-2">Registration Successful!</h3>
        <p>Thank you for registering. Your unique Entry Badge ID is:</p>
        <p id="badgeId" class="text-2xl font-mono font-bold text-white mt-2"></p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('registrationForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const msg = document.getElementById('successMessage');
  const badgeIdDisplay = document.getElementById('badgeId');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerText = 'Submitting...';

    const formData = new FormData(form);
    
    // Aggregate checkboxes into a comma-separated string
    const interestElements = form.querySelectorAll('input[name="interest"]:checked');
    const interests = Array.from(interestElements).map((el: any) => el.value).join(', ');
    formData.set('interest', interests);

    try {
      const response = await fetch('https://script.google.com/macros/s/AKfycbwc1UnTCw0lf_8aS0zs37zw93gDmJ0bgrz2eaIvvFs4JMghufHENFPke6R7-pq3uqjT/exec', {
        method: 'POST',
        body: formData
      });
      
      const result = await response.json();
      
      if (result.result === 'success') {
        form.classList.add('hidden');
        badgeIdDisplay!.innerText = result.id;
        msg?.classList.remove('hidden');
      }
    } catch (error) {
      alert('Something went wrong. Please try again.');
      btn.disabled = false;
      btn.innerText = 'Submit Registration';
    }
  });
</script>
