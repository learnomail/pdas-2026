---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | PDAS 2026">

  <!-- PAGE HERO -->
  <section class="relative min-h-[55vh] flex flex-col justify-end border-b border-slate-800 overflow-hidden pb-16">
    <!-- Grid overlay -->
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#020617] via-[#020617]/60 to-[#020617]/30"></div>
    <div class="absolute inset-0 bg-[#020617]"></div>

    <div class="container mx-auto px-4 md:px-8 relative z-10 pt-32">
      <div class="flex items-center gap-4 mb-8">
        <span class="relative w-2.5 h-2.5 flex items-center justify-center">
          <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
          <span class="relative w-2.5 h-2.5 bg-sky-400 rounded-full block"></span>
        </span>
        <p class="text-[11px] uppercase font-mono tracking-[0.2em] text-slate-400">
          SYS.COMMS // Communications Directory
        </p>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white uppercase tracking-tighter leading-[0.9] mb-8">
        Contact<br />
        <span class="text-transparent" style="-webkit-text-stroke: 1px white;">The Team</span>
      </h1>

      <p class="text-slate-300 text-lg md:text-xl max-w-2xl leading-relaxed border-l-2 border-sky-400 pl-6">
        Reach the PDAS 2026 team for exhibitor enquiries, visitor registration, media accreditation, and general summit information.
      </p>
    </div>
  </section>

  <!-- COMM CHANNELS -->
  <section class="py-24 border-b border-slate-800">
    <div class="container mx-auto px-4 md:px-8">

      <p class="text-sky-400 font-mono text-[10px] uppercase tracking-widest mb-10">01 // Communication Channels</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">

        <!-- Email -->
        <div class="border border-slate-800 bg-slate-900/50 rounded-lg p-8 flex flex-col transition-all duration-300 hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-0.5">
          <div class="flex items-center gap-3 mb-6">
            <span class="relative w-2 h-2 flex items-center justify-center">
              <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
              <span class="relative w-2 h-2 bg-sky-400 rounded-full block"></span>
            </span>
            <span class="text-sky-400 font-mono text-[10px] uppercase tracking-widest">Sys.Comms // Email</span>
          </div>
          <h2 class="text-xl font-bold text-white uppercase tracking-tight mb-6">Email Address</h2>
          <ul class="text-slate-400 space-y-3 mt-auto text-sm font-mono break-all">
            <li class="border-b border-slate-800 pb-3 hover:text-sky-400 transition-colors">
              <a href="mailto:marshallanto@thepeninsula.org.in">marshallanto@<br />thepeninsula.org.in</a>
            </li>
            <li class="border-b border-slate-800 pb-3 hover:text-sky-400 transition-colors">
              <a href="mailto:anupama@thepeninsula.org.in">anupama@<br />thepeninsula.org.in</a>
            </li>
            <li class="hover:text-sky-400 transition-colors">
              <a href="mailto:rammoorthikr@thepeninsula.org.in">rammoorthikr@<br />thepeninsula.org.in</a>
            </li>
          </ul>
        </div>

        <!-- Phone -->
        <div class="border border-slate-800 bg-slate-900/50 rounded-lg p-8 flex flex-col transition-all duration-300 hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-0.5">
          <div class="flex items-center gap-3 mb-6">
            <span class="relative w-2 h-2 flex items-center justify-center">
              <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
              <span class="relative w-2 h-2 bg-sky-400 rounded-full block"></span>
            </span>
            <span class="text-sky-400 font-mono text-[10px] uppercase tracking-widest">Sys.Comms // Voice</span>
          </div>
          <h2 class="text-xl font-bold text-white uppercase tracking-tight mb-6">Phone Number</h2>
          <ul class="text-slate-400 space-y-3 mt-auto text-sm font-mono">
            <li class="border-b border-slate-800 pb-3 hover:text-sky-400 transition-colors">
              <a href="tel:+916369448490">+91 63694 48490</a>
            </li>
            <li class="hover:text-sky-400 transition-colors">
              <a href="tel:+917989086456">+91 79890 86456</a>
            </li>
          </ul>
        </div>

        <!-- Address -->
        <div class="border border-slate-800 bg-slate-900/50 rounded-lg p-8 flex flex-col transition-all duration-300 hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-0.5">
          <div class="flex items-center gap-3 mb-6">
            <span class="relative w-2 h-2 flex items-center justify-center">
              <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
              <span class="relative w-2 h-2 bg-sky-400 rounded-full block"></span>
            </span>
            <span class="text-sky-400 font-mono text-[10px] uppercase tracking-widest">Sys.Loc // HQ</span>
          </div>
          <h2 class="text-xl font-bold text-white uppercase tracking-tight mb-6">Office Address</h2>
          <div class="text-slate-400 mt-auto text-sm font-mono leading-relaxed">
            <p class="border-b border-slate-800 pb-3 mb-3">Old No 16, New No. 17</p>
            <p class="border-b border-slate-800 pb-3 mb-3">Crescent Road, Shenoy Nagar</p>
            <p>Chennai – 600 030</p>
          </div>
        </div>

      </div>

      <!-- Venue divider -->
      <div class="flex items-center gap-4">
        <span class="w-full h-px bg-slate-800"></span>
        <p class="text-sky-400 font-mono text-[10px] uppercase tracking-[0.3em] whitespace-nowrap px-4">
          Sys.Loc // Event Venue // Chennai Trade Centre
        </p>
        <span class="w-full h-px bg-slate-800"></span>
      </div>

    </div>
  </section>

  <!-- MAP SECTION -->
  <section class="py-24 border-b border-slate-800 bg-[#070d1e]">
    <div class="container mx-auto px-4 md:px-8">

      <p class="text-sky-400 font-mono text-[10px] uppercase tracking-widest mb-10">02 // Geolocation Data</p>

      <!-- Map terminal frame -->
      <div class="relative border border-slate-800 rounded-lg p-2 bg-[#020617] shadow-[0_0_60px_-15px_rgba(56,189,248,0.15)]">
        <div class="absolute top-4 left-4 flex gap-2 z-10">
          <div class="w-2 h-2 bg-sky-400 rounded-full animate-pulse"></div>
          <div class="w-2 h-2 bg-slate-700 rounded-full"></div>
          <div class="w-2 h-2 bg-slate-700 rounded-full"></div>
        </div>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3887.3450929237893!2d80.18723527588766!3d13.013682563952596!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a5267345cb07d5b%3A0x7d6459212d295bdf!2sChennai%20Trade%20Centre%20-%20Nandambakkam!5e0!3m2!1sen!2sin!4v1776680414040!5m2!1sen!2sin"
          class="w-full h-[450px] rounded-md grayscale contrast-125 opacity-70"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <div class="flex items-center justify-between px-4 py-3 mt-1">
          <div class="flex items-center gap-3">
            <span class="relative w-2 h-2 flex items-center justify-center">
              <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
              <span class="relative w-2 h-2 bg-sky-400 rounded-full block"></span>
            </span>
            <span class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">Chennai Trade Centre — Nandambakkam</span>
          </div>
          <span class="text-[10px] font-mono text-sky-400">SYS.LOC // ACTIVE</span>
        </div>
      </div>

      <!-- Venue detail cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        <div class="border border-slate-800 bg-slate-900/60 rounded-lg p-6 font-mono transition-all duration-300 hover:border-sky-400/50 hover:-translate-y-0.5">
          <p class="text-sky-400 text-[10px] uppercase tracking-widest mb-2">Venue</p>
          <p class="text-white text-sm font-bold uppercase">Chennai Trade Centre</p>
        </div>
        <div class="border border-slate-800 bg-slate-900/60 rounded-lg p-6 font-mono transition-all duration-300 hover:border-sky-400/50 hover:-translate-y-0.5">
          <p class="text-sky-400 text-[10px] uppercase tracking-widest mb-2">Dates</p>
          <p class="text-white text-sm font-bold uppercase">20 – 22 November 2026</p>
        </div>
        <div class="border border-slate-800 bg-slate-900/60 rounded-lg p-6 font-mono transition-all duration-300 hover:border-sky-400/50 hover:-translate-y-0.5">
          <p class="text-sky-400 text-[10px] uppercase tracking-widest mb-2">Location</p>
          <p class="text-white text-sm font-bold uppercase">Nandambakkam, Chennai</p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-[#020617]">
    <div class="container mx-auto px-4 md:px-8">

      <p class="text-sky-400 font-mono text-[10px] uppercase tracking-widest mb-10">03 // Quick Connect</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-white uppercase tracking-tight mb-6 leading-none">
            Ready to<br />Participate?
          </h2>
          <p class="text-slate-400 leading-relaxed mb-10 border-l-2 border-sky-400 pl-6">
            Whether you're looking to exhibit, visit, or partner — the PDAS team is ready to brief you on the full range of opportunities at India's premier defence and aerospace summit.
          </p>
          <div class="flex flex-wrap gap-4 font-mono text-sm uppercase tracking-widest">
            <a href="/participating-options" class="bg-gradient-to-r from-blue-700 to-[#008718] text-white px-8 py-4 font-bold rounded-lg shadow-lg shadow-blue-900/30 hover:scale-[1.02] transition-all flex items-center gap-3">
              Register to Exhibit
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/visitor-profile" class="border border-slate-700 text-white px-8 py-4 font-bold rounded-lg hover:border-slate-400 transition-all bg-slate-900/50 backdrop-blur-sm">
              Register to Visit
            </a>
          </div>
        </div>

        <!-- Decorative terminal block -->
        <div class="border border-slate-800 rounded-lg p-2 bg-[#020617] shadow-[0_0_60px_-15px_rgba(56,189,248,0.15)]">
          <div class="border border-slate-800 bg-slate-900/60 rounded-md p-8 font-mono text-sm text-slate-400 leading-relaxed min-h-[200px]">
            <div class="flex items-center gap-3 mb-6">
              <span class="relative w-2 h-2">
                <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
                <span class="relative w-2 h-2 bg-sky-400 rounded-full block"></span>
              </span>
              <span class="text-sky-400 text-[10px] uppercase tracking-widest">SYS.COMMS // READY</span>
            </div>
            <p>> Exhibitor enquiries ............... <span class="text-sky-400">OPEN</span></p>
            <p class="mt-2">> Visitor registration .............. <span class="text-sky-400">OPEN</span></p>
            <p class="mt-2">> Media accreditation ............... <span class="text-sky-400">OPEN</span></p>
            <p class="mt-2">> Partnership proposals ............. <span class="text-sky-400">OPEN</span></p>
            <p class="mt-2">> Delegation requests ............... <span class="text-sky-400">OPEN</span></p>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">20–22 Nov 2026 // Chennai Trade Centre</span>
            <span class="text-[10px] font-mono text-sky-400">SYS.STATUS // ACTIVE</span>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
