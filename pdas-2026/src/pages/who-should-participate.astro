---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Who Should Participate | PDAS 2026">
  <section class="bg-[#020617] pt-12 pb-24 px-4 md:px-8 border-b border-slate-800">
    <div class="max-w-screen-xl mx-auto">
      
      <!-- DATA HEADER -->
      <div class="border-b border-slate-800 pb-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <span class="relative w-2.5 h-2.5 flex items-center justify-center">
            <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
            <span class="relative w-2.5 h-2.5 bg-sky-400 rounded-full block"></span>
          </span>
          <p class="text-[11px] uppercase font-mono tracking-[0.2em] text-slate-400">
            SYS.DIR // ATTENDANCE // WHO SHOULD PARTICIPATE
          </p>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter">
          Who Should Participate
        </h1>
        <p class="mt-6 text-xl text-slate-400 font-medium max-w-3xl leading-relaxed">
          PDAS 2026 welcomes participation from organisations and professionals across the global aerospace and defence ecosystem.
        </p>
      </div>

      <!-- GRID -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">✈️</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Aerospace & Defence</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Manufacturers, MSMEs, large enterprises and start-ups from the aerospace sector.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🛡️</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Government Agencies</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Defence agencies, armed forces and strategic decision-makers.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🤖</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Technology Providers</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            AI, robotics, avionics, cybersecurity and innovation-driven companies.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🎓</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Research Institutions</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Universities, R&D centres and academic institutions.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">⚙️</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Component Suppliers</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Component manufacturers and subsystem solution providers.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🔧</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">MRO Services</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Maintenance, repair and overhaul service providers.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">💰</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Financial Investors</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Investors, venture capital firms and financial institutions.
          </p>
        </div>

        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg hover:border-sky-400/50 hover:bg-slate-900/80 hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-2xl mb-4 grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all">🌍</div>
          <h3 class="text-white font-bold uppercase tracking-tight mb-2">Trade & Export Bodies</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Export promotion councils and international trade organisations.
          </p>
        </div>

      </div>

    </div>
  </section>
</Layout>