---
import { base } from 'astro:config/client';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Supported By | PDAS 2026">
  <section class="bg-[#020617] pt-12 pb-24 px-4 md:px-8 border-b border-slate-800">
    <div class="max-w-screen-xl mx-auto">
      
      <!-- DATA HEADER -->
      <div class="border-b border-slate-800 pb-8 mb-12">
        <div class="flex items-center gap-4 mb-4">
          <span class="relative w-2.5 h-2.5 flex items-center justify-center">
            <span class="absolute inset-0 bg-sky-400 rounded-full animate-ping opacity-60"></span>
            <span class="relative w-2.5 h-2.5 bg-sky-400 rounded-full block"></span>
          </span>
          <p class="text-[11px] uppercase font-mono tracking-[0.2em] text-slate-400">
            SYS.DIR // NETWORK // SUPPORTED BY
          </p>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter">
          Supported By
        </h1>
      </div>

      <!-- SPONSOR TIERS -->
      <div class="space-y-6 max-w-4xl">
        
        <!-- TITLE PARTNER -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Title Partner</h2>
            <span class="text-xs font-mono text-sky-400 block mt-1">Exclusive (1 Slot)</span>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹70L – ₹90L</p>
            <p>Absolute Ownership. Includes "PDAS 2026 presented by [Your Brand]" on all official assets, main stage/media wall logos, prime inaugural keynote, 2 high-level plenary sessions, largest premium pavilion in "Zone A", VIP military delegation access, and 15 VIP delegate passes.</p>
          </div>
        </div>

        <!-- ASSOCIATE PARTNERS -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Associate Sponsor</h2>
            <span class="text-xs font-mono text-sky-400 block mt-1">3 Slots</span>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹40L - ₹50L</p>
            <p>Leadership Visibility. Includes one dedicated panel speaking slot, technical session co-hosting, a premium exhibition booth in a high-visibility sector, priority access to B2B matchmaking lounges, and 10 delegate passes.</p>
          </div>
        </div>

        <!-- INDUSTRY PARTNERS -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Industry Sponsor</h2>
            <span class="text-xs font-mono text-sky-400 block mt-1">5 Slots</span>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹30L - ₹35L</p>
            <p>Includes event collateral logo placement, secondary venue branding, participation in one curated panel discussion, specialized display space, standard exhibition booth in the main hall, 10 B2B meetings, and 8 delegate passes.</p>
          </div>
        </div>

        <!-- EVENT SPONSORS -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Event Sponsor</h2>
            <span class="text-xs font-mono text-sky-400 block mt-1">5 Slots</span>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹10L - ₹15L</p>
            <p>Includes specialized display space, logo placement in designated event zones, 5 B2B meetings, and 5 delegate passes.</p>
          </div>
        </div>

        <!-- SUPPORTING PARTNERS -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Supporting</h2>
            <span class="text-xs font-mono text-sky-400 block mt-1">4 Slots</span>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹3L - ₹5L</p>
            <p>Entry-Level Presence. Includes logo presence on the official website and print materials, 5 B2B meetings, and 3 delegate passes.</p>
          </div>
        </div>

        <!-- BRANDING SPONSORS -->
        <div class="border border-slate-800 bg-slate-900/50 flex flex-col md:flex-row md:items-center p-6 rounded-lg transition-colors hover:border-sky-400/30 gap-4 md:gap-0">
          <div class="w-48 border-b md:border-b-0 md:border-r border-slate-800 mr-6 pb-2 md:py-2">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Branding</h2>
          </div>
          <div class="flex-1 text-slate-300 text-sm">
            <p class="font-semibold text-white mb-1">Investment: ₹5L</p>
            <p>High-Frequency Recall. Strategic exposure via event Lanyards, Badges, Delegate Bags, or Digital Signage, plus 2-3 passes.</p>
          </div>
        </div>

        <!-- MEDIA PARTNERS -->
        <div class="border border-slate-800 bg-slate-900/50 p-6 rounded-lg mt-12">
          <h2 class="text-xl font-bold text-white uppercase tracking-tight mb-8">Media Partners:</h2>
          
          <div class="flex flex-wrap gap-8 items-center">
            <div class="border border-slate-200 rounded-md p-4 bg-white w-48 h-24 flex items-center justify-center transition-all duration-300 hover:border-sky-400 hover:shadow-md cursor-pointer">
              <img src={`${base}/images/logos/pdas-logo-3.png`} alt="Raksha Anirveda" class="max-h-full max-w-full" />
            </div>
            
            <div class="border border-slate-200 rounded-md p-4 bg-white w-48 h-24 flex items-center justify-center transition-all duration-300 hover:border-sky-400 hover:shadow-md cursor-pointer">
              <img src={`${base}/images/logos/pdas-logo-4.png`} alt="India Strategic" class="max-h-full max-w-full" />
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>
</Layout>